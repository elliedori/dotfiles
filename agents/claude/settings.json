{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
  
    "permissions": {
      "allow": [
        "Read(/workspaces/obsidian/**)",
        "Edit(/workspaces/obsidian/**)",
        "Bash(npx eslint *)",
        "Bash(npx prettier *)",
        "Bash(just unit-test *)"
